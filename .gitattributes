# Large model binaries — track with Git LFS so clones don't carry 22MB forever.
# Enable once with:  git lfs install && git lfs migrate import --include="*.pt,*.safetensors"
*.pt              filter=lfs diff=lfs merge=lfs -text
*.safetensors     filter=lfs diff=lfs merge=lfs -text
*.bin             filter=lfs diff=lfs merge=lfs -text

# Normalize line endings for text
*.py    text eol=lf
*.js    text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
