# =============================================================================
# SENTRIX API — multi-stage, non-root, builds on a fresh clone
# =============================================================================
# Audit fixes:
#   • loghub/ is gitignored, so `COPY loghub/` broke every fresh-clone build.
#     It is now fetched at build time (idempotent, degrades gracefully offline).
#   • tests/ no longer ships in the production image (attack surface + bloat).
#   • Runs as a non-root user — if the container is ever popped (e.g. via an
#     image-parsing bug), the attacker doesn't land in a root shell.
#   • HEALTHCHECK added so `restart: unless-stopped` can actually detect a hang.
#   • Multi-stage: build tools never reach the runtime image.
# =============================================================================

# ---- builder ----------------------------------------------------------------
<<<<<<< HEAD
FROM python:3.12-slim AS builder
=======
FROM python:3.11-slim AS builder
>>>>>>> 97fc74eeed963a89e807b48050f54df99fec0d32
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt

# Fetch the small LogHub sample CSVs into the build context (a few MB).
COPY scripts/fetch_loghub.py ./scripts/fetch_loghub.py
# `|| true`: SENTRIX degrades gracefully to synthetic calibration without the
# samples, so an offline build must not fail. `mkdir -p` guarantees the dir
# exists either way — otherwise the COPY below hard-fails on an offline build,
# which is exactly the failure mode this stage exists to avoid.
RUN python scripts/fetch_loghub.py || true; mkdir -p /app/loghub

# ---- runtime ----------------------------------------------------------------
