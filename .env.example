# ============================================================
# SENTRIX — Environment Configuration (copy to .env)
#   cp .env.example .env
#
# SENTRIX runs with NO key at all on its deterministic guardrail engine.
# To unlock full AI reasoning you only need ONE thing: a single LLM API key.
# ============================================================

# ------------------------------------------------------------
# 1) THE ONE LLM KEY  (this is all you need for AI reasoning)
#    Works with ANY OpenAI-compatible provider — OpenRouter, NVIDIA NIM,
#    Groq, Together, Fireworks, DeepInfra, a local vLLM, etc.
#    Fill these three, and you're done.
#
#    LLM_PROVIDER   a label for logs (e.g. openrouter / nvidia / groq)
#    LLM_API_KEY    your key
#    LLM_MODEL      the model id from that provider
#    LLM_BASE_URL   the provider's OpenAI-compatible endpoint
#                   (omit ONLY if the provider is Google Gemini)
#
#    Example (OpenRouter free tier):
#      LLM_PROVIDER=openrouter
#      LLM_API_KEY=sk-or-...
#      LLM_MODEL=openrouter/free
#      LLM_BASE_URL=https://openrouter.ai/api/v1
# ------------------------------------------------------------
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=

# ------------------------------------------------------------
# 2) FLEET MODE — the "real-time, not simulation-only" switch
#    simulation : deterministic demo fleet (default)
#    live       : reason ONLY over real telemetry pushed to /api/ingest
#    hybrid     : simulator baseline, overridden by any live asset seen
# ------------------------------------------------------------
SENTRIX_MODE=simulation

# ------------------------------------------------------------
# 3) SECURITY — protects write/ingest endpoints
#    Required in production (the API refuses to start unprotected there).
# ------------------------------------------------------------
SENTRIX_API_TOKEN=
SENTRIX_ENV=development
SENTRIX_CORS_ORIGINS=http://localhost:3000
# Signs the tamper-evident audit trail AND outgoing action-webhook payloads
# (X-Sentrix-Signature header). Production REFUSES TO START on a default value.
# Generate one:  python -c "import secrets; print(secrets.token_hex(32))"
SENTRIX_HMAC_KEY=change-me-in-production

# ------------------------------------------------------------
# 4) AGENT LOOP
# ------------------------------------------------------------
SENTRIX_CYCLE_SECONDS=60
SENTRIX_API_WS=ws://localhost:8000/ws
SENTRIX_LOG_LEVEL=info

# ------------------------------------------------------------
# 5) ACTION EXECUTION — advisor -> operator
#    off | dry_run (default) | approve | auto
# ------------------------------------------------------------
SENTRIX_ACTION_MODE=dry_run
# Templated commands ({asset_id},{asset_name},{dataset},{tier} available):
# SENTRIX_RETRY_COMMAND=restic backup /data/{asset_id}
# SENTRIX_RESTORE_TEST_COMMAND=./scripts/restore_drill.sh {asset_id}
# Generic orchestrator webhook (Ansible/AWX, n8n, Lambda...):
# SENTRIX_ACTION_WEBHOOK=

# ------------------------------------------------------------
# 6) AGENTIC INTELLIGENCE (all optional)
# ------------------------------------------------------------
SENTRIX_AGENCY=false          # tool-use investigation on escalations/divergences
SENTRIX_CRITIC=false          # second-opinion critic before any P1/P2 page
SENTRIX_RAG=true              # similar-incident recall into reasoning prompts
SENTRIX_BATCH_SIZE=25         # assets per LLM prompt (large fleets are chunked)

# ------------------------------------------------------------
# 7) ALERTS — optional. Set only the channels you actually use.
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT=
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=
# Email alerts (optional):
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SENTRIX_ALERT_EMAIL_TO=

# ------------------------------------------------------------
# 8) LIMITS & STORAGE
# ------------------------------------------------------------
SENTRIX_RATE_LIMIT_PER_MIN=20
SENTRIX_DB_PATH=data/sentrix.db

# ------------------------------------------------------------
# 9) OPTIONAL — offline local model instead of a cloud key
#    Ollama (free, offline). Leave off unless you run it.
# ------------------------------------------------------------
SENTRIX_USE_LOCAL=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# Locally fine-tuned SLM (LoRA from scripts/slm_train.py):
SENTRIX_USE_SLM=false

# ------------------------------------------------------------
# 10) OPTIONAL — cloud persistence mirror (SQLite is built-in, no setup)
# ------------------------------------------------------------
SUPABASE_URL=
SUPABASE_KEY=

# --- LLM egress boundary -----------------------------------------------------
# Every reasoning cycle sends asset names, criticality and recovery gaps to
# LLM_BASE_URL. In production, pin the hosts prompts may reach — a misconfigured
# or injected base URL is an exfiltration path. Empty = unrestricted (dev only).
# See "What leaves your network" in SECURITY.md.
SENTRIX_LLM_ALLOWED_HOSTS=

# Fully-offline reasoning — no asset data leaves the host. Use either of these
# for privacy-sensitive fleets:
#   SENTRIX_SLM_ENABLED=true               (local fine-tuned Qwen2.5-0.5B LoRA)
#   LLM_BASE_URL=http://localhost:11434/v1 (Ollama / any self-hosted endpoint)

# --- Dashboard ---------------------------------------------------------------
# /ws is token-gated whenever SENTRIX_API_TOKEN is set. The dashboard reads the
# token from REACT_APP_WS_TOKEN at build time, or a `sentrix_token` localStorage
# key at runtime (handy for demos without rebuilding the bundle).
REACT_APP_WS_TOKEN=
